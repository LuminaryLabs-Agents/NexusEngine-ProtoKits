{
  "id": "composition-planning-domain-kit",
  "type": "domain-service-kit",
  "domain": "composition-planning",
  "domainPath": "n:registry:composition",
  "parentDomain": "registry",
  "scope": "control-domain",
  "extendsBase": "DomainServiceKit",
  "composes": ["kit-registry-domain-kit", "capability-graph-domain-kit"],
  "requires": ["n:registry:kits", "n:registry:capabilities"],
  "provides": ["n:registry:composition", "domain:composition-planning", "domain:install-plan", "domain:dependency-gap-report"],
  "ownsLoop": false,
  "resources": ["compositionPlanning.state"],
  "events": ["compositionPlanning.recipeRegistered", "compositionPlanning.planned", "compositionPlanning.validated", "compositionPlanning.snapshotLoaded", "compositionPlanning.reset"],
  "publicApi": ["createInstallPlan", "createCompositionPlanningDomainKit", "engine.n.compositionPlanning.registerRecipe", "engine.n.compositionPlanning.planComposition", "engine.n.compositionPlanning.createInstallPlan", "engine.n.compositionPlanning.validateComposition", "engine.n.compositionPlanning.suggestMissingDomains", "engine.n.compositionPlanning.scoreComposition", "engine.n.compositionPlanning.getSnapshot", "engine.n.compositionPlanning.loadSnapshot", "engine.n.compositionPlanning.reset"],
  "descriptors": ["composition-recipe", "install-plan", "dependency-gap-report", "composition-validation"],
  "boundary": "Own deterministic plan data and validation without fetching registries, importing modules, installing kits, writing files, rendering, or owning child behavior.",
  "rendererBoundary": { "ownsRenderer": false, "ownsDom": false, "ownsCanvas": false, "ownsThreeObjects": false },
  "performance": {
    "planCost": "O(selected nodes plus dependency edges)",
    "scalesWith": ["selectedKitCount", "domainCount", "bundleCount", "dependencyEdgeCount"],
    "telemetry": ["recipeCount", "planCount", "missingCount", "cycleCount", "revision"],
    "degradationModes": ["reuseCapabilityGraph", "planOneBundleAtATime", "limitSuggestionReports"]
  },
  "snapshot": { "stable": true, "version": "1.0.0", "fields": ["recipes", "plans", "validations", "missingReports", "revision"] },
  "resetPolicy": "restore configured recipes or an empty planner",
  "exportPath": "./composition-planning-domain-kit",
  "sourcePath": "protokits/composition-planning-domain-kit/index.js",
  "testPaths": ["protokits/kit-registry-domain-kit/tests/kit-registry-domain-kit.test.mjs", "tests/domain-composition-planning-smoke.test.mjs"],
  "status": "promotion-candidate",
  "metadata": { "boundary": "registry/composition", "doesNotOwn": ["registry transport", "module loading", "kit installation", "filesystem writes", "renderer", "game behavior"] }
}
