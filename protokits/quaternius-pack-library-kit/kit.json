    "quaternius-animation-clip-index-kit",
    "quaternius-animation-bank-kit",
    "quaternius-rig-profile-kit",
    "quaternius-rig-binding-kit",
    "quaternius-retarget-check-kit",
    "quaternius-root-motion-policy-kit",
    "quaternius-real-asset-playback-check-kit",
    "quaternius-material-atlas-kit",
    "quaternius-prop-library-kit",
    "quaternius-world-piece-library-kit",
    "quaternius-creature-library-kit",
    "quaternius-vehicle-library-kit",
    "quaternius-webgpu-character-shader-kit",
    "quaternius-webgpu-terrain-shader-kit"
