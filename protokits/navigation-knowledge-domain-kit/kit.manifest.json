{
  "id": "navigation-knowledge-domain-kit",
  "domain": "navigation-knowledge",
  "parentDomain": "knowledge",
  "type": "domain-service-kit",
  "status": "experimental",
  "version": "0.1.0",
  "scope": "feature-domain",
  "extendsBase": "NexusEngine DomainServiceKit",
  "requires": [],
  "provides": ["knowledge:navigation", "navigation:observer-graph", "navigation:knowledge-provenance"],
  "resources": ["navigationKnowledge.state"],
  "events": ["navigationKnowledge.discovered", "navigationKnowledge.updated", "navigationKnowledge.shared", "navigationKnowledge.stale", "navigationKnowledge.commandRejected", "navigationKnowledge.reset"],
  "publicApi": ["createNavigationKnowledgeDomainKit", "engine.n.navigationKnowledge.registerObserver", "engine.n.navigationKnowledge.observe", "engine.n.navigationKnowledge.markClosure", "engine.n.navigationKnowledge.share", "engine.n.navigationKnowledge.advance", "engine.n.navigationKnowledge.getKnownGraph", "engine.n.navigationKnowledge.getSnapshot", "engine.n.navigationKnowledge.loadSnapshot", "engine.n.navigationKnowledge.reset"],
  "descriptors": ["navigation-knowledge-fact", "known-place", "known-link", "stale-navigation-fact"],
  "boundary": "Own observer-specific navigation knowledge while Core World/Scene/Spatial own authoritative truth and hosts own pathfinding, movement, maps, fog rendering, and persistence transport.",
  "rendererBoundary": { "ownsRenderer": false, "ownsDom": false, "ownsCanvas": false, "ownsThreeObjects": false },
  "performance": { "scalesWith": ["observerCount", "factCount", "sharePacketSize", "advancedTicks"], "historyPolicy": "provenance bounded to 512", "degradationModes": ["bound share packet size", "age distant observer facts less frequently"] },
  "snapshot": { "stable": true, "version": "0.1.0", "fields": ["observers", "facts", "provenance", "tick", "processedCommands"], "loadPolicy": "schema and version validated" },
  "resetPolicy": "restore configured observers",
  "exportPath": "./navigation-knowledge-domain-kit",
  "sourcePath": "protokits/navigation-knowledge-domain-kit/index.js",
  "testPaths": ["tests/semantic-bounded-domain-kits-smoke.mjs"],
  "metadata": { "coreRelationship": "Configures Core Data and composes with Core World/Scene/Spatial without duplicating truth or pathfinding.", "idempotency": "Fact versions and command IDs make observation and sharing merges convergent.", "experimentProof": "Lost Migration multi-observer knowledge replay.", "plausibleUses": ["storm mountain routes", "shared dungeon maps"] }
}
