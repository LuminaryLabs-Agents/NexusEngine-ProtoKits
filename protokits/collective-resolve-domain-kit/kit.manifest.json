{
  "id": "collective-resolve-domain-kit",
  "domain": "collective-resolve",
  "parentDomain": "agency",
  "type": "domain-service-kit",
  "status": "experimental",
  "version": "0.1.0",
  "scope": "feature-domain",
  "extendsBase": "NexusEngine DomainServiceKit",
  "requires": [],
  "provides": ["agency:collective-resolve", "resolve:break-rally", "resolve:group-readiness"],
  "resources": ["collectiveResolve.state"],
  "events": ["resolve.changed", "resolve.shaken", "resolve.broken", "resolve.rallyStarted", "resolve.rallied", "resolve.commandRejected", "resolve.reset"],
  "publicApi": ["createCollectiveResolveDomainKit", "engine.n.collectiveResolve.registerCollective", "engine.n.collectiveResolve.setMemberReadiness", "engine.n.collectiveResolve.recordShock", "engine.n.collectiveResolve.setLeaderState", "engine.n.collectiveResolve.attemptRally", "engine.n.collectiveResolve.advance", "engine.n.collectiveResolve.getSnapshot", "engine.n.collectiveResolve.loadSnapshot", "engine.n.collectiveResolve.reset"],
  "descriptors": ["collective-resolve", "member-contribution", "rally-eligibility"],
  "boundary": "Own group resolve aggregation and rally/break semantics while Core owns agents and pressure primitives and hosts own combat, movement, dialogue, presentation, and input.",
  "rendererBoundary": { "ownsRenderer": false, "ownsDom": false, "ownsCanvas": false, "ownsThreeObjects": false },
  "performance": { "scalesWith": ["collectiveCount", "memberCount", "shockCount", "advancedTicks"], "historyPolicy": "journal configurable", "degradationModes": ["partition collectives", "reduce distant-team update frequency"] },
  "snapshot": { "stable": true, "version": "0.1.0", "fields": ["collectives", "members", "leaders", "shocks", "tick", "processedCommands"], "loadPolicy": "schema and version validated" },
  "resetPolicy": "restore configured collectives",
  "exportPath": "./collective-resolve-domain-kit",
  "sourcePath": "protokits/collective-resolve-domain-kit/index.js",
  "testPaths": ["tests/semantic-bounded-domain-kits-smoke.mjs"],
  "metadata": { "coreRelationship": "Configures Core Simulation and composes with Core Agent/Data.", "idempotency": "Member upserts and shock/rally command IDs converge; threshold transitions emit only on change.", "experimentProof": "Bridge Under Siege break/rally replay.", "plausibleUses": ["evacuation team", "defending squad"] }
