{
  "id": "kit-manifest-domain-kit",
  "type": "compatibility-bridge",
  "domain": "kit-registry",
  "parentDomain": "registry",
  "scope": "control-domain",
  "extendsBase": "kit-registry-domain-kit",
  "composes": ["kit-registry-domain-kit"],
  "requires": [],
  "provides": ["kit:manifest-registry", "kit:metadata"],
  "ownsLoop": false,
  "resources": ["kitRegistry.state via canonical owner"],
  "events": ["kitRegistry.manifestRegistered", "kitRegistry.manifestValidated", "kitRegistry.reset"],
  "publicApi": ["createKitManifestDomainKit", "normalizeKitManifest", "validateKitManifest", "engine.kitManifest compatibility alias"],
  "boundary": "Compatibility factory only; canonical registry state belongs to kit-registry-domain-kit.",
  "rendererBoundary": { "ownsRenderer": false, "ownsDom": false, "ownsCanvas": false, "ownsThreeObjects": false },
  "performance": {
    "scalesWith": ["canonicalRegistryKitCount"],
    "telemetry": ["canonicalRegistryRevision"],
    "degradationModes": ["migrateToCanonicalFactory"]
  },
  "snapshot": { "stable": true, "version": "1.0.0", "owner": "kit-registry-domain-kit" },
  "resetPolicy": "delegates to canonical registry service",
  "exportPath": "./kit-manifest-domain-kit",
  "sourcePath": "protokits/kit-manifest-domain-kit/index.js",
  "testPaths": ["tests/guided-kit-authoring-smoke.test.mjs", "protokits/kit-registry-domain-kit/tests/kit-registry-domain-kit.test.mjs"],
  "status": "compatibility-only",
  "metadata": { "boundary": "registry/kits/compatibility", "canonicalOwner": "kit-registry-domain-kit" }
}
