  "publicApi": ["createNegotiationCommitmentDomainKit", "engine.n.negotiationCommitment.openSession", "engine.n.negotiationCommitment.propose", "engine.n.negotiationCommitment.counter", "engine.n.negotiationCommitment.withdraw", "engine.n.negotiationCommitment.accept", "engine.n.negotiationCommitment.recordFulfillment", "engine.n.negotiationCommitment.recordBreach", "engine.n.negotiationCommitment.release", "engine.n.negotiationCommitment.advance", "engine.n.negotiationCommitment.settle", "engine.n.negotiationCommitment.getSnapshot", "engine.n.negotiationCommitment.loadSnapshot", "engine.n.negotiationCommitment.reset"],
