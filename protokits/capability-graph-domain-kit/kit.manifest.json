{
  "id": "capability-graph-domain-kit",
  "type": "domain-service-kit",
  "domain": "capability-graph",
  "domainPath": "n:registry:capabilities",
  "parentDomain": "registry",
  "scope": "control-domain",
  "extendsBase": "DomainServiceKit",
  "composes": ["kit-registry-domain-kit"],
  "requires": ["n:registry:kits"],
  "provides": ["n:registry:capabilities", "domain:capability-graph", "domain:dependency-graph"],
  "ownsLoop": false,
  "resources": ["capabilityGraph.state"],
  "events": ["capabilityGraph.nodeRegistered", "capabilityGraph.nodeRemoved", "capabilityGraph.built", "capabilityGraph.clusterFound", "capabilityGraph.snapshotLoaded", "capabilityGraph.reset"],
  "publicApi": ["createCapabilityGraph", "createCapabilityGraphDomainKit", "engine.n.capabilityGraph.registerDomain", "engine.n.capabilityGraph.registerMany", "engine.n.capabilityGraph.syncRegistry", "engine.n.capabilityGraph.buildGraph", "engine.n.capabilityGraph.findMissingRequires", "engine.n.capabilityGraph.findCycles", "engine.n.capabilityGraph.createInstallOrder", "engine.n.capabilityGraph.getSnapshot", "engine.n.capabilityGraph.loadSnapshot", "engine.n.capabilityGraph.reset"],
  "descriptors": ["capability-node", "dependency-edge", "missing-require", "dependency-cycle", "install-order"],
  "boundary": "Own capability nodes and deterministic dependency graph analysis without fetching, importing, installing, or owning child behavior.",
  "rendererBoundary": { "ownsRenderer": false, "ownsDom": false, "ownsCanvas": false, "ownsThreeObjects": false },
  "performance": {
    "buildCost": "O(nodes plus dependency edges)",
    "scaleProof": "1,000 registry manifests synchronized and graphed in the real NexusEngine test",
    "scalesWith": ["nodeCount", "requiresCount", "providesCount", "edgeCount"],
    "telemetry": ["nodeCount", "edgeCount", "missingCount", "cycleCount", "revision"],
    "degradationModes": ["batchRegistration", "partitionCapabilityGraphs", "reuseBuiltGraph"]
  },
  "snapshot": { "stable": true, "version": "1.0.0", "fields": ["nodes", "externalProvides", "edges", "indexes", "missing", "cycles", "missingReports", "clusters", "revision"] },
  "resetPolicy": "restore configured capability manifests and external providers",
  "exportPath": "./capability-graph-domain-kit",
  "sourcePath": "protokits/capability-graph-domain-kit/index.js",
  "testPaths": ["protokits/kit-registry-domain-kit/tests/kit-registry-domain-kit.test.mjs", "tests/domain-composition-planning-smoke.test.mjs"],
  "status": "promotion-candidate",
  "metadata": { "boundary": "registry/capabilities", "doesNotOwn": ["registry transport", "module loading", "installation", "renderer", "game behavior"] }
}
