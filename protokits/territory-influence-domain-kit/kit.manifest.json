{
  "id": "territory-influence-domain-kit",
  "domain": "territory-influence",
  "parentDomain": "world",
  "type": "domain-service-kit",
  "status": "experimental",
  "version": "0.1.0",
  "scope": "feature-domain",
  "extendsBase": "NexusEngine DomainServiceKit",
  "requires": [],
  "provides": ["world:territory-influence", "territory:contest", "territory:control-transitions"],
  "resources": ["territoryInfluence.state"],
  "events": ["territory.influenceChanged", "territory.contested", "territory.controlChanged", "territory.neutralized", "territory.commandRejected", "territory.reset"],
  "publicApi": ["createTerritoryInfluenceDomainKit", "engine.n.territoryInfluence.registerRegion", "engine.n.territoryInfluence.contribute", "engine.n.territoryInfluence.withdraw", "engine.n.territoryInfluence.lockContest", "engine.n.territoryInfluence.releaseContest", "engine.n.territoryInfluence.advance", "engine.n.territoryInfluence.getController", "engine.n.territoryInfluence.getSnapshot", "engine.n.territoryInfluence.loadSnapshot", "engine.n.territoryInfluence.reset"],
  "descriptors": ["territory-control", "territory-contest", "influence-contribution-read-model"],
  "boundary": "Own faction influence and control semantics over portable region IDs while Core owns spatial/scene truth and hosts own combat, economy, movement, maps, and networking.",
  "rendererBoundary": { "ownsRenderer": false, "ownsDom": false, "ownsCanvas": false, "ownsThreeObjects": false },
  "performance": { "scalesWith": ["regionCount", "contributionCount", "factionCount", "advancedTicks"], "historyPolicy": "transitions bounded to 256", "degradationModes": ["partition regions", "aggregate distant contributions"] },
  "snapshot": { "stable": true, "version": "0.1.0", "fields": ["regions", "contributions", "transitions", "tick", "processedCommands"], "loadPolicy": "schema and version validated" },
  "resetPolicy": "restore configured regions",
  "exportPath": "./territory-influence-domain-kit",
  "sourcePath": "protokits/territory-influence-domain-kit/index.js",
  "testPaths": ["tests/semantic-bounded-domain-kits-smoke.mjs"],
  "metadata": { "coreRelationship": "Composes with Core Spatial/Scene/Data and configures Core Simulation without duplicating region truth.", "idempotency": "Contribution command IDs apply once and resolved transitions emit only on state change.", "experimentProof": "Border Accord tie/decay/control replay.", "plausibleUses": ["strategy frontline", "civic districts"] }
}
