{
  "id": "quaternius-terrain-walker-kit",
  "name": "Quaternius Terrain Walker Kit",
  "version": "0.1.0",
  "stability": "prototype",
  "domain": "quaternius-terrain-walker",
  "type": "composite-protokit",
  "description": "Composite ProtoKit graph for Quaternius humanoid characters, semantic animation banks, terrain grounding, third-person movement, and camera descriptors.",
  "requires": ["terrain-sampler"],
  "provides": ["quaternius-terrain-walker", "humanoid-animation-bank", "third-person-terrain-walker"],
  "entry": "./index.js",
  "runtimeSurface": ["engine.n.quaterniusTerrainWalker", "engine.quaterniusTerrainWalker"],
  "rendererOwnership": "host-only",
  "hostConcernsForbiddenInReusableKit": ["DOM", "Canvas", "Three.js", "WebGL", "GLTFLoader", "fetch", "localStorage", "Date.now", "unseeded-random"],
  "validation": {
    "headless": "tests/quaternius-terrain-walker-kit-smoke.test.mjs",
    "mustProve": [
      "kit suite creates installable runtime kits",
      "semantic idle/walk/run clips can be registered",
      "actor moves from input",
      "terrain height grounding is applied",
      "snapshot is serializable"
    ]
  },
  "kitGraph": [
    "quaternius-source-manifest-kit",
    "quaternius-pack-import-kit",
    "asset-receipt-kit",
    "asset-deny-path-kit",
    "glb-normalization-kit",
    "runtime-asset-promotion-kit",
    "humanoid-character-loader-kit",
    "humanoid-rig-descriptor-kit",
    "quaternius-character-profile-kit",
    "character-scale-normalizer-kit",
    "character-material-safe-kit",
    "quaternius-animation-manifest-kit",
    "animation-clip-loader-kit",
    "animation-name-cleanup-kit",
    "animation-category-kit",
    "animation-bank-kit",
    "humanoid-skeleton-binding-kit",
    "bone-map-kit",
    "rest-pose-alignment-kit",
    "root-motion-policy-kit",
    "quaternion-orientation-kit",
    "clip-retarget-validation-kit",
    "third-person-input-kit",
    "character-motor-kit",
    "locomotion-state-kit",
    "animation-blend-kit",
    "camera-relative-movement-kit",
    "third-person-camera-kit",
    "character-grounding-kit",
    "terrain-heightfield-kit",
    "terrain-sampler-kit",
    "terrain-collision-lite-kit",
    "slope-alignment-kit",
    "terrain-lod-ring-kit",
    "terrain-material-paint-kit",
    "quaternius-terrain-walker-game-kit",
    "character-debug-panel-kit",
    "animation-preview-mode-kit",
    "spawn-point-kit",
    "world-reset-kit"
  ]
}
