{
  "id": "banded-infinite-terrain-kit",
  "version": "0.1.0",
  "domain": "banded-infinite-terrain",
  "kind": "composite-domain",
  "stability": "prototype",
  "provides": [
    "terrain:banded-infinite-terrain",
    "terrain:band-policy",
