{
  "id": "agriculture-domain-kit",
  "domain": "agriculture",
  "domainPath": "n:production:agriculture",
  "parentDomain": "production",
  "type": "domain-service-kit",
  "status": "promotion-ready",
  "scope": "feature-domain",
  "extendsBase": "nexusengine/core-simulation",
  "composes": ["n:core-transaction-ledger"],
  "requires": ["n:core-transaction-ledger"],
  "provides": [
    "production:agriculture",
    "agriculture:land",
    "agriculture:soil",
    "agriculture:cultivation",
    "agriculture:harvest"
  ],
  "resources": ["production.agriculture.state"],
  "events": [
    "agriculture.plot.prepared",
    "agriculture.crop.planted",
    "agriculture.crop.watered",
    "agriculture.crop.stageChanged",
    "agriculture.crop.ready",
    "agriculture.crop.harvested",
    "agriculture.day.resolved",
    "agriculture.command.rejected",
    "agriculture.snapshot.loaded",
    "agriculture.reset"
  ],
  "publicApi": [
    "createAgricultureDomainKit",
    "engine.n.agriculture.land",
    "engine.n.agriculture.soil",
    "engine.n.agriculture.cultivation",
    "engine.n.agriculture.water",
    "engine.n.agriculture.growth",
    "engine.n.agriculture.harvest",
    "engine.n.agriculture.perennials",
    "engine.n.agriculture.getSnapshot",
    "engine.n.agriculture.loadSnapshot",
    "engine.n.agriculture.reset"
  ],
  "descriptors": ["agriculture-plot"],
  "boundary": "Own farm land, soil, cultivation, watering, growth, harvest, and perennial crop meaning while inventory, weather, calendar, wild resources, rendering, and storage remain separate.",
  "rendererBoundary": {
    "ownsRenderer": false,
    "ownsDom": false,
    "ownsCanvas": false,
    "ownsThreeObjects": false,
    "forbidden": ["DOM", "Canvas", "WebGL", "Three.js", "browser input", "asset loading", "wall-clock time", "unseeded random"]
  },
  "performance": {
    "tickCost": "O(active growing plot count)",
    "lookupCost": "O(1) by stable plot id",
    "historyPolicy": "bounded by journalLimit; default 128",
    "scaleProof": "tropical and temperate multi-configuration headless fixtures",
    "scalesWith": ["plotCount", "activeCropCount"],
    "telemetry": ["plotCount", "activeCropCount", "currentDay", "totalHarvests", "revision"]
  },
  "snapshot": {
    "stable": true,
    "version": "1.0.0",
    "schema": "nexusengine.agriculture/1",
    "fields": ["currentDay", "plots", "cropIds", "totalHarvests", "journal", "revision"],
    "loadPolicy": "validate plot and crop identities before replacing live state"
  },
  "resetPolicy": "restore configured plots, soil, and empty cultivation state",
  "exportPath": "./agriculture-domain-kit",
  "sourcePath": "protokits/agriculture-domain-kit/index.js",
  "testPaths": ["protokits/agriculture-domain-kit/tests/agriculture-domain-kit.test.mjs"],
  "metadata": {
    "purpose": "Reusable service-driven agriculture authority under the production domain family.",
    "sourceRepositories": ["LuminaryLabs-Agents/NexusEngine-ProtoKits", "LuminaryLabs-Publish/MyCozyIsland"],
    "doesNotOwn": ["inventory", "economy", "wild foraging", "weather generation", "calendar", "player stamina", "quests", "rendering", "persistence transport"]
  }
}
