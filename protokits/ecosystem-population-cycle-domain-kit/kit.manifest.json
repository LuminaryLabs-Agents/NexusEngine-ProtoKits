  "scope": "feature-domain",
  "extendsBase": "NexusEngine DomainServiceKit",
  "requires": [],
  "provides": ["ecology:population-cycle", "ecology:trophic-flow", "ecology:capacity-pressure"],
  "resources": ["ecosystemPopulation.state"],
