  "publicApi": ["createEcosystemPopulationCycleDomainKit", "engine.n.ecosystemPopulation.registerSpecies", "engine.n.ecosystemPopulation.registerFeedingLink", "engine.n.ecosystemPopulation.setCapacity", "engine.n.ecosystemPopulation.applyMigration", "engine.n.ecosystemPopulation.advanceCycle", "engine.n.ecosystemPopulation.getRegion", "engine.n.ecosystemPopulation.getSnapshot", "engine.n.ecosystemPopulation.loadSnapshot", "engine.n.ecosystemPopulation.reset"],
  "descriptors": ["ecosystem-region-population", "trophic-flow", "capacity-pressure-summary"],
