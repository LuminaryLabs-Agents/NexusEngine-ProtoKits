  "metadata": { "coreRelationship": "Configures Core Simulation/Data and composes with Core World.", "idempotency": "Stable species/link IDs and migration command IDs; same seed and cycles replay.", "experimentProof": "Rewilding Basin cohort replay across two datasets.", "plausibleUses": ["reef restoration", "alpine reserve"] }
