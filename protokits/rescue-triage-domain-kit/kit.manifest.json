{
  "id": "rescue-triage-domain-kit",
  "domain": "rescue-triage",
  "parentDomain": "rescue",
  "type": "domain-service-kit",
  "status": "experimental",
  "version": "0.1.0",
  "scope": "feature-domain",
  "extendsBase": "NexusEngine DomainServiceKit",
  "requires": [],
  "provides": ["rescue:triage", "triage:priority", "triage:treatment-stages", "triage:transport-readiness"],
  "resources": ["rescueTriage.state"],
  "events": ["triage.assessed", "triage.categoryChanged", "triage.treatmentStarted", "triage.stabilized", "triage.deteriorated", "triage.transportReady", "triage.outcomeResolved", "triage.commandRejected", "triage.reset"],
  "publicApi": ["createRescueTriageDomainKit", "engine.n.rescueTriage.registerCasualty", "engine.n.rescueTriage.assess", "engine.n.rescueTriage.beginTreatment", "engine.n.rescueTriage.completeTreatment", "engine.n.rescueTriage.markTransported", "engine.n.rescueTriage.advance", "engine.n.rescueTriage.resolveOutcome", "engine.n.rescueTriage.getPriorityQueue", "engine.n.rescueTriage.getSnapshot", "engine.n.rescueTriage.loadSnapshot", "engine.n.rescueTriage.reset"],
  "descriptors": ["triage-priority", "treatment-readiness", "transport-readiness", "rescue-outcome"],
  "boundary": "Own abstract fictional rescue priority and care-stage meaning while Core owns primitives and hosts own damage, medical content, inventories, transport movement, rendering, and UI; not clinical guidance.",
  "rendererBoundary": { "ownsRenderer": false, "ownsDom": false, "ownsCanvas": false, "ownsThreeObjects": false },
  "performance": { "scalesWith": ["casualtyCount", "treatmentCount", "advancedTicks"], "historyPolicy": "treatment and outcome ledgers bounded to 256", "degradationModes": ["partition incidents", "lower inactive-casualty update frequency"] },
  "snapshot": { "stable": true, "version": "0.1.0", "fields": ["casualties", "treatments", "outcomes", "tick", "processedCommands"], "loadPolicy": "schema and version validated" },
  "resetPolicy": "restore configured fictional incident",
  "exportPath": "./rescue-triage-domain-kit",
  "sourcePath": "protokits/rescue-triage-domain-kit/index.js",
  "testPaths": ["tests/semantic-bounded-domain-kits-smoke.mjs"],
  "metadata": { "coreRelationship": "Configures Core Simulation/Interaction/Data and composes with Core Agent without duplicating health or interaction primitives.", "idempotency": "Assessment/treatment command IDs apply once and outcomes resolve once.", "experimentProof": "Quarantine Lantern abstract rescue replay.", "plausibleUses": ["storm evacuation", "collapsing-city rescue"] }
}
